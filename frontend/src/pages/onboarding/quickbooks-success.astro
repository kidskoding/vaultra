---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="QuickBooks Connected">
  <div class="min-h-screen flex items-center justify-center bg-claude-bg px-4">
    <div class="w-full max-w-md bg-claude-cream rounded-2xl border border-claude-sand p-8 text-center">
      <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-6 bg-white overflow-hidden">
        <svg viewBox="0 0 128 128" class="w-14 h-14" aria-hidden="true">
          <path d="M64 128c35.346 0 64-28.654 64-64S99.346 0 64 0 0 28.654 0 64s28.654 64 64 64z" fill="#2ca01c" />
          <path
            d="M17.778 64a24.889 24.889 0 0 0 24.889 24.889h3.555v-9.245h-3.555a15.645 15.645 0 1 1 0-31.289H51.2v48.356a9.248 9.248 0 0 0 9.244 9.245V39.111H42.667A24.889 24.889 0 0 0 17.777 64zm67.555-24.889h-3.555v9.245h3.555a15.645 15.645 0 0 1 0 31.288H76.8V31.29a9.244 9.244 0 0 0-9.244-9.245V88.89h17.777a24.888 24.888 0 0 0 0-49.778z"
            fill="#fff"
          />
        </svg>
      </div>
      <h1 class="text-xl font-semibold text-claude-charcoal mb-2">QuickBooks Connected!</h1>
      <p class="text-sm text-claude-gray-warm mb-8 leading-relaxed">
        Your QuickBooks account has been connected successfully. We can now analyze your financial data.
      </p>
      <a href="/dashboard" class="w-full bg-claude-coral text-white py-3 rounded-xl font-medium hover:bg-claude-coral-dark transition-colors block">
        Go to Dashboard
      </a>
    </div>
  </div>
</BaseLayout>
